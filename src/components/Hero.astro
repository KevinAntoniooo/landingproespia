---
// Hero.astro — Sección principal de conversión con formulario
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-[#05070F] py-24 md:py-32" id="hero">

  <!-- Laser scan line -->
  <div class="absolute left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-cyan-500/40 to-transparent animate-pulse pointer-events-none z-[5]" style="top:45%"></div>

  <!-- Background layer -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[url('/assets/Home_Cotiza_Imagen-2-2.jpg')] bg-center bg-cover bg-no-repeat saturate-[0.6] brightness-[0.25]"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#05070F]/90 via-[#05070F]/60 to-[#05070F]/30"></div>
    <div class="absolute inset-0" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,255,0,0.015) 2px, rgba(0,255,0,0.015) 4px);"></div>
    <div class="absolute inset-0" style="background-image: repeating-linear-gradient(90deg, transparent, transparent 3px, rgba(0,255,0,0.01) 3px, rgba(0,255,0,0.01) 5px);"></div>
  </div>

  <!-- Content grid -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-8 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 items-center">

    <!-- Left content -->
    <div class="space-y-6">
      <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-500/10 border border-red-500/30 text-red-400 text-xs font-mono font-bold uppercase animate-pulse">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500 inline-block"></span>
        Central Conectada Alpha III Carabineros
      </span>

      <h1 class="text-[clamp(2rem,4.2vw,3.2rem)] font-black leading-[1.1] tracking-tight text-white">
        Protegemos tu hogar o empresa en <span class="bg-gradient-to-r from-blue-400 to-blue-500 bg-clip-text text-transparent">Rancagua</span> con <span class="bg-gradient-to-r from-blue-400 to-blue-500 bg-clip-text text-transparent">tecnología de punta</span>
      </h1>

      <p class="text-base md:text-lg text-gray-400 leading-relaxed max-w-[540px]">
        Disuadimos robos con monitoreo técnico en tiempo real de cámaras y alarmas. Respuesta inmediata ante cualquier alerta crítica en tu propiedad, sin importar la hora.
      </p>

      <div class="flex flex-wrap gap-8">
        <div>
          <span class="text-2xl font-black text-white">+7.000</span>
          <span class="block text-xs text-gray-500 font-medium mt-0.5">Propiedades protegidas</span>
        </div>
        <div>
          <span class="text-2xl font-black text-white">&lt; 30s</span>
          <span class="block text-xs text-gray-500 font-medium mt-0.5">Alerta técnica</span>
        </div>
        <div>
          <span class="text-2xl font-black text-white">24/7</span>
          <span class="block text-xs text-gray-500 font-medium mt-0.5">Monitoreo continuo</span>
        </div>
      </div>
    </div>

    <!-- Form card -->
    <div class="flex justify-end">
      <div class="w-full max-w-[440px] bg-[#0A0D1A]/95 backdrop-blur border border-red-500/20 rounded-2xl p-7 md:p-9 shadow-[0_25px_60px_rgba(0,0,0,0.5)]">
        <div class="text-center mb-6">
          <i class="fa-solid fa-shield-halved text-3xl text-red-500 mb-3"></i>
          <h3 class="text-lg font-bold text-white">EVALUAR MI BRECHA DE SEGURIDAD GRATIS — RESPUESTA EN 15 MINUTOS</h3>
          <p class="text-sm text-gray-400">Recibe un diagnóstico táctico inmediato sin compromiso</p>
        </div>

        <form class="flex flex-col gap-3.5" id="heroForm">
          <div>
            <label for="heroName" class="block text-[0.7rem] font-semibold text-gray-400 uppercase tracking-[0.3px] mb-1 font-mono">Nombre completo</label>
            <input type="text" id="heroName" class="w-full bg-[#05070F] border border-white/10 rounded-lg px-4 py-3.5 text-white font-mono text-sm placeholder-slate-400 focus:border-red-500 focus:ring-1 focus:ring-red-500/30 transition-all" placeholder="Ej: Juan Pérez" required />
          </div>
          <div>
            <label for="heroPhone" class="block text-[0.7rem] font-semibold text-gray-400 uppercase tracking-[0.3px] mb-1 font-mono">Teléfono</label>
            <input type="tel" id="heroPhone" class="w-full bg-[#05070F] border border-white/10 rounded-lg px-4 py-3.5 text-white font-mono text-sm placeholder-slate-400 focus:border-red-500 focus:ring-1 focus:ring-red-500/30 transition-all" placeholder="+56 9 1234 5678" required />
          </div>
          <div>
            <label for="heroProperty" class="block text-[0.7rem] font-semibold text-gray-400 uppercase tracking-[0.3px] mb-1 font-mono">Tipo de Propiedad</label>
            <select id="heroProperty" class="w-full bg-[#05070F] border border-white/10 rounded-lg px-4 py-3.5 text-white font-mono text-sm focus:border-red-500 focus:ring-1 focus:ring-red-500/30 transition-all" required>
              <option value="" disabled selected class="bg-[#05070F] text-slate-400">Selecciona una opción</option>
              <option value="casa" class="bg-[#05070F]">Casa</option>
              <option value="local" class="bg-[#05070F]">Local Comercial</option>
              <option value="bodega" class="bg-[#05070F]">Bodega / Galpón</option>
              <option value="industria" class="bg-[#05070F]">Industria</option>
            </select>
          </div>
          <button type="submit" class="w-full bg-gradient-to-r from-red-600 to-orange-600 hover:from-red-500 hover:to-orange-500 text-white font-black uppercase tracking-wider py-4 rounded-lg shadow-xl shadow-red-600/20 transition-all mt-1">
            <i class="fa-solid fa-circle-check mr-2"></i>
            Evaluar Mi Propiedad Gratis
          </button>
          <p class="text-center text-xs text-gray-500 mt-0.5 font-mono">Sin compromiso · Respuesta en menos de 24 hrs</p>
        </form>
      </div>
    </div>

  </div>

  <!-- Wave separator -->
  <div class="absolute bottom-0 left-0 w-full h-[60px] z-10 pointer-events-none overflow-hidden">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full h-full fill-[#080C16]">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" />
    </svg>
  </div>

</section>

<script>
  document.getElementById('heroForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fa-solid fa-circle-check mr-2"></i> ¡Recibido! Te contactaremos pronto';
    btn.style.pointerEvents = 'none';
    setTimeout(() => { btn.innerHTML = orig; btn.style.pointerEvents = ''; }, 4000);
  });
</script>
