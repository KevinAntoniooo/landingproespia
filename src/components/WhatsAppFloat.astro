---
// WhatsAppFloat.astro — Botón flotante con pulso concéntrico
---

<div class="whatsapp-float">
  <a href="https://wa.me/56722266383?text=Hola!%20Quiero%20cotizar%20seguridad%20para%20mi%20propiedad" target="_blank" rel="noopener" class="whatsapp-float__btn" aria-label="WhatsApp Pro Espía">
    <i class="fa-brands fa-whatsapp"></i>
  </a>
  <div class="whatsapp-float__ring"></div>
  <div class="whatsapp-float__ring whatsapp-float__ring--delay"></div>
</div>

<style>
  .whatsapp-float {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: wa-float-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1s both;
  }

  @keyframes wa-float-in {
    from { opacity: 0; transform: translateY(40px) scale(0.8); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .whatsapp-float__btn {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--whatsapp);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1.8rem;
    box-shadow: 0 6px 24px rgba(37, 211, 102, 0.4);
    transition: var(--transition);
    position: relative;
    z-index: 2;
  }

  .whatsapp-float__btn:hover {
    transform: scale(1.1);
    box-shadow: 0 8px 32px rgba(37, 211, 102, 0.5);
  }

  .whatsapp-float__ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 3px solid var(--whatsapp);
    transform: translate(-50%, -50%);
    animation: wa-pulse 2.5s ease-out infinite;
    opacity: 0;
    z-index: 1;
    pointer-events: none;
  }

  .whatsapp-float__ring--delay {
    animation-delay: 0.8s;
  }

  @keyframes wa-pulse {
    0% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
    100% { transform: translate(-50%, -50%) scale(1.8); opacity: 0; }
  }

  @media (max-width: 480px) {
    .whatsapp-float {
      bottom: 16px;
      right: 16px;
    }

    .whatsapp-float__btn {
      width: 52px;
      height: 52px;
      font-size: 1.5rem;
    }

    .whatsapp-float__ring {
      width: 52px;
      height: 52px;
    }
  }
</style>
